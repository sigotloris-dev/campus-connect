# Copia questo file in ".env" e riempi i valori.

# Postgres (Neon): DATABASE_URL = "pooled", DIRECT_URL = diretta (per le migrazioni)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/db?sslmode=require"

# Segreto per i cookie di sessione — genera con: openssl rand -hex 32
AUTH_SECRET=""

# Cifratura Server Actions — genera con: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""

# Vercel Blob (storage foto) — dal pannello Vercel > Storage > Blob
BLOB_READ_WRITE_TOKEN=""
